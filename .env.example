# Vision provider: openai (default) or gemini
# AI_PROVIDER=openai

# OpenAI — required when AI_PROVIDER=openai (key is server-side only, never exposed to the browser)
OPENAI_API_KEY=sk-your-key-here
# Optional: override vision model (default: gpt-5.1)
# OPENAI_MODEL=gpt-5.1

# Gemini — required when AI_PROVIDER=gemini (uses Google's OpenAI-compatible endpoint)
# GEMINI_API_KEY=your-key-here
# Optional: override vision model (default: gemini-3.1-pro-preview)
# GEMINI_MODEL=gemini-3.1-pro-preview

# Local dev: run API server in a second terminal
# npm run dev:server
# npm run dev
